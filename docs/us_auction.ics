BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//US-Market-Calendar//EN
CALSCALE:GREGORIAN
X-WR-CALNAME:🇺🇸 国債入札
REFRESH-INTERVAL;VALUE=DURATION:PT1H
X-APPLE-CALENDAR-COLOR:#34C759
X-PUBLISHED-TTL:PT1H
X-WR-TIMEZONE:America/New_York
BEGIN:VTIMEZONE
TZID:America/New_York
BEGIN:STANDARD
DTSTART:19701101T020000
RRULE:FREQ=YEARLY;BYDAY=1SU;BYMONTH=11
TZNAME:EST
TZOFFSETFROM:-0400
TZOFFSETTO:-0500
END:STANDARD
BEGIN:DAYLIGHT
DTSTART:19700308T020000
RRULE:FREQ=YEARLY;BYDAY=2SU;BYMONTH=3
TZNAME:EDT
TZOFFSETFROM:-0500
TZOFFSETTO:-0400
END:DAYLIGHT
END:VTIMEZONE
END:VCALENDAR
