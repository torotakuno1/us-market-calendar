BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//US-Market-Calendar//EN
CALSCALE:GREGORIAN
X-WR-CALNAME:🇺🇸 OpEx/VIX
REFRESH-INTERVAL;VALUE=DURATION:PT1H
X-APPLE-CALENDAR-COLOR:#FF9500
X-PUBLISHED-TTL:PT1H
X-WR-TIMEZONE:America/New_York
BEGIN:VTIMEZONE
TZID:America/New_York
BEGIN:STANDARD
DTSTART:19701101T020000
RRULE:FREQ=YEARLY;BYDAY=1SU;BYMONTH=11
TZNAME:EST
TZOFFSETFROM:-0400
TZOFFSETTO:-0500
END:STANDARD
BEGIN:DAYLIGHT
DTSTART:19700308T020000
RRULE:FREQ=YEARLY;BYDAY=2SU;BYMONTH=3
TZNAME:EDT
TZOFFSETFROM:-0500
TZOFFSETTO:-0400
END:DAYLIGHT
END:VTIMEZONE
BEGIN:VEVENT
SUMMARY:★★ VIX最終決済
DTSTART:20260415T123000Z
DTEND:20260415T123500Z
DTSTAMP:20260418T015104Z
UID:0012d8bbc318e239@us-market-cal
CATEGORIES:opex
DESCRIPTION:VIX Final Settlement (AM settlement)\nET 08:30 / JST 21:30\n
 出典: CBOE (vix_exceptions.csv)\nSOQ (Special Opening Quotation) で決
 済値算出 | 通常（水曜）
TRANSP:TRANSPARENT
